+
+  it("updates expenses only for the authenticated user", async () => {
+    const eqUser = vi.fn(async () => ({ error: null }));
+    const eqId = vi.fn(() => ({ eq: eqUser }));
+    const update = vi.fn(() => ({ eq: eqId }));
