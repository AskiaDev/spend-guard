+    await user.click(screen.getByRole("button", { name: "Save Expense" }));
+
+    expect(onUpdateExpense).toHaveBeenCalledWith("expense_utilities", {
+      label: "Utilities and internet",
+      amount: 7000,
+      dueDay: 15,
+      isRecurring: true,
+    });
