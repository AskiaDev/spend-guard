NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback, only if your project does not have an sb_publishable_ key yet.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI advisor (model-agnostic, optional) ---
# Ordered, comma-separated transport chain for the advisor explanation. The app
# tries each in order and uses the first that responds; with this unset it uses the
# deterministic narrative only (no model, no network). Values: local, cloud, mock.
#   local = on-device LiteRT-LM (WebGPU, data never leaves the device)
#   cloud = hosted model via the server route (keys stay server-side)
# NEXT_PUBLIC_AI_PROVIDER=local,cloud

# On-device model file for the `local` transport (defaults to Gemma E2B).
# NEXT_PUBLIC_LITERT_MODEL_URL=https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/main/gemma-4-E2B-it-web.litertlm

# Cloud model for the `cloud` transport, as "<provider>:<modelId>". Swap models by
# editing this one line; add a vendor with one entry in src/lib/ai/model-spec.ts.
# Provider must be one of: anthropic, openai. (Server-only — never exposed to the client.)
# ADVISOR_MODEL=anthropic:claude-haiku-4-5

# API key for the cloud provider above (server-only). Set the one matching ADVISOR_MODEL.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
